    /* SYSTEMATIC FIX #8: Enhanced tempo dot states */
    @keyframes tempoPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }

    /* AutoUndo blink for loop display */
    .loop-display.auto-undo-blink {
