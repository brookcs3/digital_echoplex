        position: absolute;
        color: #ccc;
        font-size: 0.65vw;
        text-align: center;
        white-space: nowrap;
        transform: translateX(-50%);
    }

    /* Parameter matrix grid */
    .parameter-matrix {
        position: absolute;
        left: 53%;
        bottom: 13%;
        width: 39%;
        height: 22%;
        background: rgba(34, 34, 34, 0.26);
