    }

    .button {
        transition: all 0.1s;
        border-radius: 50%;
        width: 50px;
        height: 50px;
    }

    .button:active {
        transform: scale(0.95);
    }

    .button-image {
        position: absolute;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, #f8f8f8, #d0d0d0);
